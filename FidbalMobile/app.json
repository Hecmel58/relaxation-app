{
  "expo": {
    "name": "FidBal",
    "slug": "FidbalMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "fidbal",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hecmel.fidbal",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "FidBal uygulaması görüntülü görüşme özelliği için kamera erişimine ihtiyaç duyar.",
        "NSMicrophoneUsageDescription": "FidBal uygulaması görüntülü görüşme ve ses kaydı özellikleri için mikrofon erişimine ihtiyaç duyar.",
        "NSPhotoLibraryUsageDescription": "FidBal uygulaması fotoğraf seçmek için medya kütüphanesine erişmek istiyor.",
        "NSUserTrackingUsageDescription": "Bu bilgi, uygulama deneyiminizi iyileştirmek ve size daha iyi hizmet sunmak için kullanılacaktır.",
        "UIBackgroundModes": ["audio", "remote-notification"],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C12.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["C12.1"]
          }
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.associated-domains": []
      },
      "usesAppleSignIn": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.hecmel.fidbal",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "fidbal"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "61f6b7c6-54a2-4315-81a7-6f8fc7095f0a"
      },
      "privacyPolicyUrl": "https://fidbal.com/privacy-policy",
      "termsOfServiceUrl": "https://fidbal.com/terms-of-service",
      "supportUrl": "https://fidbal.com/support",
      "demoUser": {
        "phone": "5555551144",
        "password": "*Demo58*",
        "notes": "Demo account for store review - Full access",
        "name": "Demo Reviewer"
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b82f6",
          "androidMode": "default",
          "androidCollapsedTitle": "FidBal Bildirimleri"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FidBal uygulaması görüntülü görüşme için kameranıza erişmek istiyor.",
          "microphonePermission": "FidBal uygulaması görüntülü görüşme için mikrofonunuza erişmek istiyor.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "FidBal uygulaması ses kaydı için mikrofonunuza erişmek istiyor.",
          "backgroundAudio": {
            "ios": {
              "mode": "audio"
            },
            "android": {
              "foregroundService": {
                "notificationTitle": "FidBal Binaural Ses",
                "notificationBody": "Binaural ses çalınıyor",
                "notificationColor": "#3b82f6"
              }
            }
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FidBal uygulaması fotoğraf seçmek için medya kütüphanesine erişmek istiyor.",
          "cameraPermission": "FidBal uygulaması fotoğraf çekmek için kameranıza erişmek istiyor."
        }
      ],
      [
        "expo-dev-client"
      ]
    ],
    "owner": "hecmel",
    "newArchEnabled": false
  }
}